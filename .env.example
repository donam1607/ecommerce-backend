PORT=5000
DATABASE_URL=postgresql://username:password@host:5432/dbname
JWT_SECRET=replace_with_a_long_random_secret
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Security / rate limits
CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
JSON_BODY_LIMIT=1mb
URLENCODED_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_API_MAX=300
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_CHAT_WINDOW_MS=60000
RATE_LIMIT_CHAT_MAX=20
RATE_LIMIT_UPLOAD_WINDOW_MS=3600000
RATE_LIMIT_UPLOAD_MAX=60
RATE_LIMIT_COUPON_WINDOW_MS=300000
RATE_LIMIT_COUPON_MAX=60

# Cloudinary (required for /api/upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
